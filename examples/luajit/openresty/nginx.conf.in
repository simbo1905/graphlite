worker_processes 1;

env GRAPHLITE_DB_PATH;
env GRAPHLITE_LIB;

error_log __RUNTIME__/logs/error.log info;

pid __RUNTIME__/nginx.pid;

events {
    worker_connections 1024;
}

http {
    default_type application/json;

    lua_package_path "__ROOT__/?.lua;;";

    server {
        listen __PORT__;
        server_name localhost;

        location / {
            default_type text/html;
            root __ROOT__;
            try_files /index.html =404;
        }

        location /graphsite.lua {
            default_type application/json;
            content_by_lua_file __ROOT__/graphsite.lua;
        }
    }
}
